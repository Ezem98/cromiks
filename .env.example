# —— App ——
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Cromiks

# —— Supabase ——
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=

# —— Cloudflare R2 ——
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=cromiks-assets
R2_PUBLIC_URL=

# —— Upstash Redis (anti-abuso) ——
# Create DB en upstash.com, region sa-east-1 (mismo que Supabase).
# Copiá los valores REST API del dashboard.
# Si están vacías → ratelimit fail-open (no limita nada). OK para dev.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Kill switch (cualquier entorno): RATELIMIT_DISABLED=true desactiva el limiter.
# RATELIMIT_DISABLED=

# —— PostHog ——
# Project key + host están hardcodeados en src/lib/posthog/config.ts (key es
# pública, igual que el DSN de Sentry). Solo necesitás los kill switches.
# Kill switches (cualquier entorno): apagan PostHog sin desinstalar el paquete.
# POSTHOG_DISABLED=                 # server / edge
# NEXT_PUBLIC_POSTHOG_DISABLED=     # client

# —— Resend (email transaccional) ——
RESEND_API_KEY=
RESEND_FROM_EMAIL=hola@cromiks.com

# —— Sentry ——
# DSN está hardcodeado en sentry.*.config.ts (es público, va al bundle igual).
# Org/Project están hardcodeados en next.config.ts.
# Solo el auth token es secret y va por env (Vercel build env + .env.sentry-build-plugin local).
SENTRY_AUTH_TOKEN=
# Kill switches (cualquier entorno): apagan Sentry sin desinstalar el paquete.
# SENTRY_DISABLED=                  # server / edge
# NEXT_PUBLIC_SENTRY_DISABLED=      # client

# —— Playwright E2E ——
# Email del user de prueba. El global-setup lo crea idempotentemente vía admin SDK
# y genera un magic link para inyectar la sesión. Usá un email dedicado.
PLAYWRIGHT_TEST_USER_EMAIL=e2e@cromiks.app
# Opcional: override del baseURL (default http://localhost:3000)
# PLAYWRIGHT_BASE_URL=

# —— Auth providers ——
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
