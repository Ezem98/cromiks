# Las env vars que el proceso Next lee se validan al boot/build en `src/env.ts`
# (TP-11 · @t3-oss/env-nextjs). Si falta o está vacía una [requerida], el build
# FALLA con un error claro en vez de romper en runtime.
# Escape hatch para lint/type-check/CI sin secrets: SKIP_ENV_VALIDATION=1.

# —— App ——
NEXT_PUBLIC_APP_URL=http://localhost:3000   # [requerida] magic links + metadataBase
NEXT_PUBLIC_APP_NAME=Cromiks                # [no usada por Next — fuera de env.ts]

# —— Supabase ——
NEXT_PUBLIC_SUPABASE_URL=                   # [requerida]
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=       # [requerida]
SUPABASE_SECRET_KEY=                        # [requerida] solo server (admin client + scripts)

# —— Cloudflare R2 ——
# [fuera de env.ts] R2 todavía no está wired en src/. Cuando se integre, se agregan al schema.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=cromiks-assets
R2_PUBLIC_URL=

# —— Upstash Redis (anti-abuso) ——
# Create DB en upstash.com, region sa-east-1 (mismo que Supabase).
# [opcional en dev/preview — fail-open]. env.ts las EXIGE cuando
# RAILWAY_ENVIRONMENT_NAME=production (ratelimit fail-open no permitido en prod).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# [kill switch · opt-in · crudo, fuera de env.ts] RATELIMIT_DISABLED=true desactiva el limiter.
# RATELIMIT_DISABLED=

# —— PostHog ——
# [opcional] Project key del dashboard (phc_...). Es pública (se inlinea igual).
# Si está vacía → el SDK no manda eventos.
NEXT_PUBLIC_POSTHOG_KEY=
# Host hardcodeado en src/lib/posthog/config.ts (us.i.posthog.com). No es env.
# [kill switches · opt-in · crudos, fuera de env.ts]
# POSTHOG_DISABLED=                 # server / edge
# NEXT_PUBLIC_POSTHOG_DISABLED=     # client

# —— Resend (email transaccional) ——
# [requerida] La consume Supabase Auth (SMTP, dashboard), NO el proceso Next.
# Se declara en env.ts igual como guard de presencia: un Railway sin esta var
# falla el build en vez de romper los mails OTP en silencio (incidente PR6).
RESEND_API_KEY=
RESEND_FROM_EMAIL=hola@cromiks.com          # [opcional] default en env.ts

# —— Sentry ——
# DSN está hardcodeado en sentry.*.config.ts (es público, va al bundle igual).
# Org/Project están hardcodeados en next.config.ts.
# [fuera de env.ts] Lo lee el webpack plugin de Sentry en build, no el runtime.
SENTRY_AUTH_TOKEN=
# [kill switches · opt-in · crudos, fuera de env.ts]
# SENTRY_DISABLED=                  # server / edge
# NEXT_PUBLIC_SENTRY_DISABLED=      # client

# —— Railway (platform-injected) ——
# [opcional] Railway las inyecta en runtime; next.config.ts las espeja a
# NEXT_PUBLIC_RAILWAY_* para el bundle client. No hace falta setearlas en local.
# RAILWAY_ENVIRONMENT_NAME=
# RAILWAY_GIT_COMMIT_SHA=

# —— Playwright E2E ——
# [tooling · crudo, fuera de env.ts] Corre fuera del runtime de la app.
# Email del user de prueba. El global-setup lo crea idempotentemente vía admin SDK.
PLAYWRIGHT_TEST_USER_EMAIL=e2e@cromiks.app
# Opcional: override del baseURL (default http://localhost:3000)
# PLAYWRIGHT_BASE_URL=

# —— Auth providers ——
# [fuera de env.ts] OAuth se configura en el dashboard de Supabase, no en código.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_CLIENT_ID=
APPLE_TEAM_ID=
APPLE_KEY_ID=
APPLE_PRIVATE_KEY=
